// Descrição   : Verificar se os números digitados pelo usuário são múltiplos
// Autor(a)    : Nathalia Suzin
// Data atual  : 10/03/2021

VAR
    a, b: INTEIRO
    
INICIO
    ESCREVA(“Informe os valores: ”)
    LEIA (a,b)
    SE (a MOD b = 0) OU (b MOD a = 0) ENTAO 
        ESCREVAL(a, “ E “, b, “ SÃO MÚLTIPLOS”)
    SENAO
        ESCREVAL(a, “ E “, b, “ NÃO SÃO MÚLTIPLOS”)
    FIMSE
FIMALGORITMO 
