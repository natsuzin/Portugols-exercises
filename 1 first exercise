// Descrição   : Encontrar o volume de um objeto
// Autor(a)    : Nathalia Suzin
// Data atual  : 10/03/2021

Var
   raio, altura, volume: Real

Inicio
   Escreval("Digite o raio do objeto :")
   leia(raio)
   Escreval("Digite a altura do objeto :")
   leia(altura)
   volume <- PI * raio ^ 2 * altura
   Escreval("Volume =", volume)

Fimalgoritmo
