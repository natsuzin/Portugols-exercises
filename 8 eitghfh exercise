// Descrição   : Ler o sexo e altura de uma pessoa e calcular seu peso ideal, considerando que:
// para homens o peso ideal é igual a (72,7 * altura) - 58 
// e para mulheres o peso ideal é igual a (62.1 * altura) - 44.7
// Autor(a)    : Nathalia Suzin
// Data atual  : 10/03/2021

VAR
    sexo: CARACTERE
    peso, altura, pesoIdeal: REAL
    
INICIO
    ESCREVA(“Informe sexo, altura e peso:”)
    LEIA (sexo, altura, peso)
    ESCOLHA(SEXO)
        CASO “F”:
            pesoIdeal <- 62.1 * altura – 44.7
        CASO “M”: 
            pesoIdeal <- 72.7 * altura – 58
    FIMESCOLHA
    ESCREVAL(“Seu peso ideal eh ”, pesoIdeal)
FIMALGORITMO 
